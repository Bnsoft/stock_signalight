# Signalight Phase 9 Environment Variables

# ============= Backend (FastAPI) =============
# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# Supabase Configuration (optional - SQLite fallback if not set)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Database
DB_PATH=./data/signalight.db

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# ============= Frontend (Next.js) =============
# API Base URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Vercel Deployment
VERCEL_URL=https://signalight.vercel.app
NEXT_PUBLIC_VERCEL_URL=https://signalight.vercel.app

# ============= Email & Notifications =============
# Resend Email Service
RESEND_API_KEY=your-resend-api-key

# Discord Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Slack Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id
